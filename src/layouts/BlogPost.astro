---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  section: 'biosecurity' | 'writing' | 'notes';
  backHref: string;
  backLabel: string;
}

const { title, description, pubDate, tags, section, backHref, backLabel } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const sectionStyles = {
  biosecurity: { tagBg: 'bg-emerald-50', tagText: 'text-emerald-700', accent: 'from-emerald-500 to-teal-600', link: 'text-emerald-600 hover:text-emerald-800' },
  writing:     { tagBg: 'bg-indigo-50',  tagText: 'text-indigo-700',  accent: 'from-indigo-500 to-violet-600', link: 'text-indigo-600 hover:text-indigo-800'  },
  notes:       { tagBg: 'bg-amber-50',   tagText: 'text-amber-700',   accent: 'from-amber-400 to-orange-500',  link: 'text-amber-600 hover:text-amber-800'   },
} as const;

const styles = sectionStyles[section];
---

<Layout title={`${title} — Your Blog`} description={description}>
  <Header />

  <!-- Section accent bar at top of page -->
  <div class={`h-1 bg-gradient-to-r ${styles.accent}`} />

  <main class="max-w-2xl mx-auto px-6 py-16">
    <a href={backHref} class={`inline-flex items-center text-sm font-medium mb-10 ${styles.link}`}>
      {backLabel}
    </a>

    <article>
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          {
            tags.map((tag) => (
              <span class={`px-2 py-0.5 ${styles.tagBg} ${styles.tagText} text-xs rounded font-medium`}>
                {tag}
              </span>
            ))
          }
        </div>
        <h1 class="text-4xl font-bold text-navy mb-3">{title}</h1>
        <time class="text-sm text-gray-400">{formattedDate}</time>
      </header>

      <div
        class="prose prose-gray max-w-none
          prose-headings:text-navy prose-headings:font-bold
          prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline
          prose-code:text-indigo-700 prose-code:bg-indigo-50 prose-code:px-1 prose-code:rounded
          prose-pre:bg-gray-900 prose-pre:text-gray-100"
      >
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Layout>
