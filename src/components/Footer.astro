---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 py-8 bg-white">
  <div class="max-w-5xl mx-auto px-6 flex items-center justify-between flex-wrap gap-4">
    <p class="text-sm text-gray-400">
      &copy; {year} Your Name. All rights reserved.
    </p>
    <div class="flex gap-6">
      <a href="/#about" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
        About
      </a>
      <a href="/#projects" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
        Projects
      </a>
      <a href="/blog" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
        Blog
      </a>
    </div>
  </div>
</footer>
