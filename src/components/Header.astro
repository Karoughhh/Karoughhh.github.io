---
const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/#projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-navy font-semibold text-lg tracking-tight">
      Your Name
    </a>
    <nav class="flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-gray-600 hover:text-navy transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
