---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const collectionMap = {
  biosecurity: '/blog/biosecurity',
  writing: '/blog/writing',
  notes: '/blog/notes',
} as const;

type CollectionName = keyof typeof collectionMap;

const allPosts = (
  await Promise.all(
    (Object.entries(collectionMap) as [CollectionName, string][]).map(
      async ([name, prefix]) => {
        const entries = await getCollection(name, ({ data }) => !data.draft);
        return entries.map((post) => ({
          title: post.data.title,
          description: post.data.description,
          pubDate: post.data.pubDate,
          tags: post.data.tags,
          href: `${prefix}/${post.slug}`,
        }));
      },
    ),
  )
).flat();

const latestPosts = allPosts
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf())
  .slice(0, 3);
---

<Layout>
  <Header />
  <main>
    <Hero />
    <About />
    <Projects />
    {latestPosts.length > 0 && <BlogPreview posts={latestPosts} />}
    <Contact />
  </main>
  <Footer />
</Layout>
