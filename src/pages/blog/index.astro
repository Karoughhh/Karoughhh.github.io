---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="Blog — Your Name"
  description="Writing on software development, systems, and tooling."
>
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-navy mb-4">Blog</h1>
    <p class="text-gray-600 mb-12">Thoughts on software, systems, and building things.</p>

    <div class="space-y-6">
      {
        posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="block group">
            <article class="border-b border-gray-100 pb-6">
              <div class="flex flex-wrap gap-1 mb-2">
                {post.data.tags.map((tag: string) => (
                  <span class="px-2 py-0.5 bg-indigo-50 text-indigo-700 text-xs rounded font-medium">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors mb-1">
                {post.data.title}
              </h2>
              <p class="text-gray-600 text-sm mb-2">{post.data.description}</p>
              <time class="text-xs text-gray-400">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </article>
          </a>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
